# Railway Environment Variables for SkwirlsAI
# Copy this to Railway dashboard and fill in your values

# Server Configuration
SERVER_PORT=3001
STORAGE_DIR=/app/server/storage

# Security - IMPORTANT: Generate secure random strings before deploying
# You can generate these at: https://generate.random.org/
SIG_KEY=CHANGE_ME_TO_RANDOM_32_CHARS_MIN
SIG_SALT=CHANGE_ME_TO_RANDOM_32_CHARS_MIN
JWT_SECRET=CHANGE_ME_TO_RANDOM_12_CHARS_MIN

# Authentication password for remote access
AUTH_TOKEN=CHANGE_ME_TO_SECURE_PASSWORD

# LLM Provider - Start with OpenAI for testing
LLM_PROVIDER=openai
OPEN_AI_KEY=sk-your-openai-key-here
OPEN_MODEL_PREF=gpt-4o

# Embedding Configuration
EMBEDDING_ENGINE=openai
# OPEN_AI_KEY is reused from above
EMBEDDING_MODEL_PREF=text-embedding-ada-002

# Vector Database - LanceDB is default and works well for single instance
VECTOR_DB=lancedb

# Disable telemetry (optional)
DISABLE_TELEMETRY=true

# Telemetry - Set to false to enable anonymous usage stats (optional)
# DISABLE_TELEMETRY=false
